{
  "name": "betterprompts-phase11-security-tests",
  "version": "1.0.0",
  "description": "Phase 11: Security Testing - OWASP Top 10 Compliance",
  "scripts": {
    "test": "playwright test",
    "test:sql": "playwright test ss-01-sql-injection.spec.ts",
    "test:xss": "playwright test ss-02-xss-protection.spec.ts",
    "test:auth": "playwright test ss-03-authentication.spec.ts",
    "test:session": "playwright test ss-04-session-management.spec.ts",
    "test:encryption": "playwright test ss-05-encryption.spec.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:with-zap": "npm run zap:start && npm test && npm run zap:stop",
    "zap:start": "docker run -d --name zap-security -p 8090:8090 owasp/zap2docker-stable zap.sh -daemon -host 0.0.0.0 -port 8090",
    "zap:stop": "docker stop zap-security && docker rm zap-security",
    "zap:scan": "docker run -v $(pwd)/reports:/zap/reports:rw -t owasp/zap2docker-stable zap-baseline.py -t http://host.docker.internal:3000 -g gen.conf -r ZAP-Report.html",
    "report:generate": "node ./utils/generate-report.js",
    "pretest": "node ./utils/setup-test-data.js",
    "posttest": "node ./utils/cleanup-test-data.js"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}