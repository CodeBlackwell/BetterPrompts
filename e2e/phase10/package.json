{
  "name": "phase10-rate-limiting-tests",
  "version": "1.0.0",
  "description": "Phase 10: Rate Limiting & Concurrent Access E2E Tests",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:rate-limits": "playwright test us-015-rate-limiting.spec.ts",
    "test:concurrent": "playwright test ec-06-concurrent-access.spec.ts",
    "test:headers": "playwright test rate-limit-headers.spec.ts",
    "test:distributed": "playwright test distributed-limiting.spec.ts",
    "test:report": "playwright show-report",
    "test:perf": "playwright test ec-06-concurrent-access.spec.ts --reporter=json",
    "test:all": "playwright test --workers=1",
    "setup:db": "node test-data-setup.js setup",
    "teardown:db": "node test-data-setup.js teardown",
    "reset:db": "node test-data-setup.js reset",
    "pretest": "node test-data-setup.js setup",
    "posttest": "node test-data-setup.js reset"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "@types/redis": "^4.0.11",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "redis": "^3.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}