{
  "name": "betterprompts-phase8-tests",
  "version": "1.0.0",
  "description": "Performance metrics and load testing for BetterPrompts",
  "scripts": {
    "test": "playwright test",
    "test:dashboard": "playwright test us-005-performance-metrics.spec.ts",
    "test:stress": "playwright test dashboard-stress.spec.ts",
    "test:sla": "playwright test sla-compliance.spec.ts",
    "test:all": "playwright test",
    "k6:local": "k6 run scenarios/load-test-all.k6.js",
    "k6:cloud": "k6 cloud scenarios/load-test-all.k6.js",
    "k6:ramp": "k6 run scenarios/ramp-up.k6.js",
    "k6:sustained": "k6 run scenarios/sustained-load.k6.js",
    "k6:spike": "k6 run scenarios/spike-test.k6.js",
    "k6:geo": "k6 run scenarios/geo-distributed.k6.js",
    "report": "node utils/generate-report.js",
    "dashboard:setup": "node utils/setup-dashboard.js",
    "validate": "npm run test:sla && npm run k6:local"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
