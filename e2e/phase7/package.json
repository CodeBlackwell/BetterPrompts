{
  "name": "betterprompts-phase7-e2e",
  "version": "1.0.0",
  "description": "Phase 7 E2E tests for BetterPrompts Enterprise API Integration",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:api": "playwright test us-004-api-integration.spec.ts",
    "test:contract": "playwright test api-contract.spec.ts",
    "test:webhook": "playwright test webhook-delivery.spec.ts",
    "test:all": "playwright test --reporter=html",
    "test:ci": "playwright test --reporter=list,json",
    "postinstall": "playwright install",
    "generate:docs": "node scripts/generate-docs.js",
    "generate:postman": "node scripts/generate-postman.js",
    "generate:sdk-examples": "node scripts/generate-sdk-examples.js"
  },
  "keywords": [
    "e2e",
    "api",
    "testing",
    "playwright",
    "enterprise"
  ],
  "author": "BetterPrompts Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.4",
    "@types/uuid": "^9.0.7",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1"
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "jsonwebtoken": "^9.0.2"
  }
