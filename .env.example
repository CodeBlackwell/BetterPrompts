# Docker Registry
DOCKER_REGISTRY=docker.io/betterprompts
VERSION=latest

# API Configuration
API_URL=https://api.betterprompts.ai/api/v1

# Database Configuration
DATABASE_URL=postgresql://betterprompts:changeme@postgres:5432/betterprompts
POSTGRES_USER=betterprompts
POSTGRES_PASSWORD=changeme
POSTGRES_DB=betterprompts

# Redis Configuration
REDIS_URL=redis://:changeme@redis:6379/0
REDIS_PASSWORD=changeme

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_URL=https://monitoring.betterprompts.ai
ELASTIC_PASSWORD=changeme

# SSL Configuration (for production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# ===== E2E TEST CONFIGURATION =====

# Test Environment
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080/api/v1
TEST_ENVIRONMENT=local

# Test User Credentials
# These users must be pre-seeded in the database for tests to pass
TEST_POWER_USER_EMAIL=poweruser@example.com
TEST_POWER_USER_PASSWORD=PowerUser123!

TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=AdminPassword123!

# API Test Configuration
TEST_API_KEY=test-api-key-12345
TEST_WEBHOOK_URL=https://example.com/webhooks

# Feature Flags (for conditional tests)
FEATURE_VOICE_INPUT=true
FEATURE_OFFLINE_MODE=true
FEATURE_WEBHOOKS=true
FEATURE_BATCH_PROCESSING=true

# Test Data Settings
SEED_TEST_USERS=true
TEST_USER_COUNT=100
BATCH_USER_COUNT=50

# Performance Thresholds
MAX_PAGE_LOAD_TIME=3000
MAX_API_RESPONSE_TIME=500
MAX_BATCH_PROCESSING_TIME=120000

# Concurrency Settings
MAX_CONCURRENT_USERS=200
BROWSER_POOL_SIZE=20
RATE_LIMIT_PER_MINUTE=100

# Test Execution Settings
HEADLESS=true
SLOW_MO=0
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_RETRY=true

# CI/CD Settings
CI=false
PARALLEL_WORKERS=1
TEST_RETRIES=2

# Debug Settings
DEBUG=false
VERBOSE_LOGGING=false