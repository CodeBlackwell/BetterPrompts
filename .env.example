# Docker Registry
DOCKER_REGISTRY=docker.io/betterprompts
VERSION=latest

# API Configuration
API_URL=http://localhost/api/v1
PORT=8090
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://betterprompts:changeme@postgres:5432/betterprompts
POSTGRES_USER=betterprompts
POSTGRES_PASSWORD=changeme
POSTGRES_DB=betterprompts

# Redis Configuration
REDIS_URL=redis://:changeme@redis:6379/0
REDIS_PASSWORD=changeme

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
HUGGINGFACE_API_KEY=hf-your-huggingface-api-key

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_URL=https://monitoring.betterprompts.ai
ELASTIC_PASSWORD=changeme

# SSL Configuration (for production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# Request Settings
REQUEST_TIMEOUT=30

# API Documentation
ENABLE_DOCS=true
ENABLE_SWAGGER_UI=true

# ML Model Settings
USE_TORCHSERVE=false
TORCHSERVE_HOST=torchserve
TORCHSERVE_PORT=8080
MODEL_NAME=microsoft/deberta-v3-base

# CORS Settings (for API access from different domains)
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key

# Performance Settings
MAX_WORKERS=4
CONNECTION_POOL_SIZE=10
CACHE_TTL=3600

# Security
BCRYPT_COST=10
SESSION_TIMEOUT=86400

# Optional API Key Authentication
API_KEY_ENABLED=false
# API keys should be managed in your database or secret management system